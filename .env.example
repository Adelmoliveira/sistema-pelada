# Copie este arquivo para .env.local e preencha com suas credenciais
# O arquivo .env.local será carregado automaticamente em desenvolvimento

# URL de conexão com o PostgreSQL do Supabase
# Formato: postgresql://usuario:senha@host:porta/database
DATABASE_URL=postgresql://postgres.PROJECT_REF:SENHA_CODIFICADA@aws-0-REGIAO.pooler.supabase.com:6543/postgres

# Chave secreta para sessões (mude em produção!)
# Gere uma com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-super-secreta-alegatoria-desenvolvimento

# Integração Pix Mercado Pago
# Use primeiro as credenciais de teste e nunca envie estes valores ao Git.
MERCADOPAGO_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000
MERCADOPAGO_WEBHOOK_SECRET=sua-assinatura-secreta-do-webhook
APP_BASE_URL=https://seu-projeto.vercel.app
